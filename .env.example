# Point this domain to the VPS before configuring HTTPS.
DOMAIN=notes.example.com

# Administrator credential used only to create and list users.
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=replace-with-at-least-32-random-characters

# Allow users to create their own accounts in the Android app.
ALLOW_REGISTRATION=true


# Login sessions expire after this many hours (default: 30 days).
SESSION_TTL_HOURS=720

# Only requests coming directly from these proxy CIDRs may supply X-Real-IP.
# With Docker, set this to the exact gateway address of the API container network (/32).
# Leave empty until you have verified the gateway; untrusted headers will be ignored.
TRUSTED_PROXY_CIDRS=
# Bootstrap owner account shown in the app.
OWNER_USERNAME=owner

# Owner account access token. Generate with: openssl rand -hex 32
SYNC_TOKEN=replace-with-at-least-32-random-characters

# Owner encryption key. Generate with: openssl rand -base64 32
# Never change after the owner has synchronized data.
DATA_KEY=replace-with-base64-32-byte-key