# Point this domain to the VPS before starting Caddy.
DOMAIN=notes.example.com

# Generate separately with: openssl rand -hex 32
SYNC_TOKEN=replace-with-at-least-32-random-characters

# Generate with: openssl rand -base64 32
# This encrypts synchronized notes. Never change it after first sync.
DATA_KEY=replace-with-base64-32-byte-key